# PostgreSQL
POSTGRES_DB=boardapp
POSTGRES_USER=boardapp
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# JWT — wygeneruj: openssl rand -base64 64
JWT_SECRET=CHANGE_ME_LONG_RANDOM_JWT_SECRET

# Publiczny adres VM (lub domena), np. http://1.2.3.4 lub https://boardapp.example.com
REACT_APP_API_URL=http://YOUR_VM_PUBLIC_IP
